# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Volitelné — přímý Postgres connection string (jen lokálně, nikdy do gitu).
# Supabase Dashboard → Project Settings → Database → Connection string → URI.
# Použití: pnpm db:seed:timeline:remote (nahraje supabase/seed_recent_two_months.sql do produkce).
# SUPABASE_DB_DIRECT_URL=

# Anthropic
ANTHROPIC_API_KEY=

# Telegram (token len v .env / Secret Manager — nikdy do gitu; meno bota napr. @AgentZizka_bot)
TELEGRAM_BOT_TOKEN=
# Tajný řetězec — musí sedět s setWebhook secret_token a s hlavičkou z Telegramu
TELEGRAM_WEBHOOK_SECRET=
# Volitelné: pokud je vyplněno, jen tato čísla (Telegram user id) smí psát botu. Zjistíš u @userinfobot
TELEGRAM_ALLOWED_USER_IDS=
# Volitelné — jen uživatelské jméno bota pro odkaz t.me v Nastavení (bez @)
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=AgentZizka_bot

# Google (Kalendář OAuth)
# GOOGLE_REDIRECT_URI musí přesně odpovídat „Authorized redirect URIs“ v Google Cloud Console
# (např. http://localhost:3000/api/auth/google/callback nebo https://váš-web/api/auth/google/callback).
# Dokud je OAuth consent screen ve stavu „Testing“, jen účty v „Test users“ se mohou přihlásit.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Email
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=
